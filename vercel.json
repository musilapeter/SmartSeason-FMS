{
  "builds": [
    {
      "src": "server/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/src/index.ts" },
    { "source": "/(.*)", "destination": "/client/dist/$1" }
  ]
}
